# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── AI Provider ────────────────────────────────────────────
# "openai"  → GPT-4o via OpenAI API (requires API key, has rate limits)
# "ollama"  → Local model via Ollama (free, no API key, runs on your machine)
AI_PROVIDER=openai

# ── OpenAI (used when AI_PROVIDER=openai) ─────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Ollama (used when AI_PROVIDER=ollama) ─────────────────
# Install: https://ollama.com  then: ollama pull qwen2.5-coder:7b
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# ── GitHub App (preferred) ─────────────────────────────────
# Use your GitHub App ID and private key for webhook authentication.
GITHUB_APP_ID=3349093
# GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
# (paste the full private key here, including headers and footers)
# -----END RSA PRIVATE KEY-----

# Optional legacy GitHub token (not required for GitHub App auth)
# GITHUB_TOKEN=

# ── CORS (optional) ───────────────────────────────────────
CORS_ORIGINS=*
